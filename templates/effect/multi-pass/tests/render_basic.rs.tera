//! GPU render test for {{ effect_name }}.
//!
//! Runs the full two-pass pipeline ({{ pass1_kernel_name }} → {{ pass2_kernel_name }})
//! on a checkerboard and writes the output as a PNG.
//!
//! Requires a GPU (Metal on macOS, CUDA on Windows).

use prgpu::testing::{GpuContext, builtin_checkerboard, write_png};
use {{ crate_name }}::kernel::{
    {{ pass1_kernel_name }}, {{ pass1_kernel_params_name }},
    {{ pass2_kernel_name }}, {{ pass2_kernel_params_name }},
};

#[test]
fn render_checkerboard_two_pass() {
    let gpu = GpuContext::create().expect("GPU context creation");

    let (w, h) = (512, 512);
    let input = builtin_checkerboard(w, h);

    // Pass 1 buffers: source → edge detection
    let (in_buf, edge_buf) = gpu.create_io_buffers(w, h, 4).expect("pass1 buffers");
    gpu.upload_to_buffer(&in_buf, &input, w, h, 4).expect("upload");

    // Pass 2 output buffer
    let out_buf = gpu.create_buffer(w, h, 4, 0x50415332).expect("pass2 output"); // "PAS2"

    // ── Pass 1: edge detection ──
    let pass1_params = {{ pass1_kernel_params_name }} {
        edge_strength: 1.0_f32,
        edge_threshold: 0.3_f32,
        edge_width: 1.0_f32,
        edge_src_width: w,
        edge_src_height: h,
        edge_src_pitch: in_buf.pitch_px,
    };

    let config1 = gpu.build_config(&in_buf, &edge_buf, w, h, 4);
    unsafe { {{ pass1_kernel_name }}(&config1, pass1_params).expect("pass1 dispatch") };

    // ── Pass 2: composite ──
    let pass2_params = {{ pass2_kernel_params_name }} {
        opacity: 1.0_f32,
        tint_r: 0.0_f32,
        tint_g: 0.0_f32,
        tint_b: 1.0_f32,
        tint_a: 1.0_f32,
        edge_width: w,
        edge_height: h,
        edge_pitch: edge_buf.pitch_px,
    };

    // Pass 2 reads edge result from outgoing, original from incoming.
    let mut config2 = gpu.build_config(&edge_buf, &out_buf, w, h, 4);
    config2.incoming_data = Some(in_buf.data);
    config2.incoming_pitch_px = in_buf.pitch_px as i32;

    unsafe { {{ pass2_kernel_name }}(&config2, pass2_params).expect("pass2 dispatch") };

    let output = gpu.download_from_buffer(&out_buf, w, h, 4).expect("download");

    assert!(!output.is_empty(), "output is empty");
    let has_nonzero = output.iter().any(|&b| b != 0);
    assert!(has_nonzero, "output is all black — pipeline may not have run");

    write_png("tests/output/basic.png", &output, w, h, 4).expect("write png");
}
